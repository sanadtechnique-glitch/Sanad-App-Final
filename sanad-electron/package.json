{
  "name": "sanad-desktop",
  "version": "1.0.0",
  "description": "Sanad - Digital City Windows Desktop Application",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.sanad.benguerdane",
    "productName": "Sanad",
    "copyright": "Copyright © 2025 Sanad Digital City",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "www",
        "to": "www"
      },
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icon.png",
      "artifactName": "Sanad-Setup-${version}-${arch}.zip",
      "sign": null,
      "signingHashAlgorithms": null,
      "certificateFile": null,
      "rfc3161TimeStampServer": null
    },
    "compression": "maximum",
    "removePackageScripts": true,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "npmRebuild": false,
    "forceCodeSigning": false
  },
  "devDependencies": {
    "electron": "^33.4.5",
    "electron-builder": "^25.1.8"
  }
}
